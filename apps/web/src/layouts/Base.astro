---
import '../styles/global.css'
export interface Props {
	title: string
}
const { title } = Astro.props
---

<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<title>{title}</title>
	</head>
	<body class='min-h-screen bg-surface-0'>
		<header class='border-b border-border'>
			<div
				class='mx-auto flex max-w-6xl items-center justify-between px-6 py-4'
			>
				<span class='text-sm font-semibold'>Poll Overlay</span>
				<nav class='flex gap-4 text-sm text-text-secondary'>
					<a href='/dashboard' class='hover:text-text-primary'
						>Dashboard</a
					>
				</nav>
			</div>
		</header>
		<div class='mx-auto max-w-6xl px-6 py-8'>
			<slot />
		</div>
	</body>
</html>
